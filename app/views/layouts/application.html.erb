<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "The Book Shelf" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <a href="/" class="navbar-brand">📚 Book Tracker</a>
      <div class="navbar-links">
        <% if current_user != nil %>
          <a href="/user_books" class="nav-link">My Books</a>
          <a href="/recommendations" class="nav-link">Recommendations</a>
          <a href="/user_books/new" class="nav-link nav-link-cta">+ Add Book</a>
          <span class="nav-divider">|</span>
          <a href="/session/destroy" class="nav-link nav-link-signout">Sign Out</a>
        <% else %>
          <a href="/session/new" class="nav-link">Sign In</a>
        <% end %>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="flash flash-notice"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="flash flash-alert"><%= alert %></div>
    <% end %>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
